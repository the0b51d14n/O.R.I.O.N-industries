# =============================================================================
# ORION INDUSTRIES — .env.example
# ⚠️  Copier ce fichier en .env et remplir les valeurs
# ⚠️  Ne JAMAIS committer .env — uniquement .env.example
# =============================================================================
# cp .env.example .env
# =============================================================================


# =============================================================================
# GENERAL
# =============================================================================

NODE_ENV=development
# development | staging | production


# =============================================================================
# API — NestJS (apps/api)
# =============================================================================

API_PORT=3000
API_URL=http://localhost:3000
API_PREFIX=api


# =============================================================================
# DATABASE — PostgreSQL + Prisma (apps/api)
# =============================================================================

# URL de connexion complète (utilisée par Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/orion_db

# Détails individuels (utilisés par Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orion_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password


# =============================================================================
# AUTH — JWT (apps/api)
# =============================================================================

# Secret de signature des tokens JWT (min. 64 caractères, aléatoire)
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_replace_this

JWT_EXPIRES_IN=15m

# Secret du refresh token (différent du JWT_SECRET)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_replace_this

JWT_REFRESH_EXPIRES_IN=7d


# =============================================================================
# FRONTEND — React + Vite (apps/web)
# =============================================================================

VITE_API_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
VITE_APP_NAME=Orion Industries
VITE_APP_VERSION=0.1.0
VITE_APP_ENV=development


# =============================================================================
# ADMIN — Dashboard interne (apps/admin)
# =============================================================================

VITE_ADMIN_API_URL=http://localhost:3000/api
VITE_ADMIN_WS_URL=ws://localhost:3000
VITE_ADMIN_APP_NAME=Orion Industries — Admin


# =============================================================================
# CORS
# =============================================================================

# Origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174


# =============================================================================
# REDIS (sessions, queues, cache) — optionnel en dev
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# =============================================================================
# EMAIL
# =============================================================================

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=no-reply@orion-industries.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM="Orion Industries <no-reply@orion-industries.com>"


# =============================================================================
# STORAGE — Fichiers & uploads
# =============================================================================

# local | s3 | gcs
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads

# AWS S3 (si STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=

# Google Cloud Storage (si STORAGE_DRIVER=gcs)
GCS_BUCKET=
GCS_KEY_FILE=


# =============================================================================
# OAUTH — Providers sociaux (optionnel)
# =============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback


# =============================================================================
# SECURITY
# =============================================================================

# Clé de chiffrement pour les données sensibles en base (32 chars hex)
ENCRYPTION_KEY=your_32_char_hex_encryption_key_here

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CSRF
CSRF_SECRET=your_csrf_secret_here


# =============================================================================
# MONITORING & LOGS
# =============================================================================

# error | warn | log | debug | verbose
LOG_LEVEL=debug

# Sentry (error tracking)
SENTRY_DSN=

# OpenTelemetry (tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=


# =============================================================================
# DOCKER
# =============================================================================

COMPOSE_PROJECT_NAME=orion-industries
